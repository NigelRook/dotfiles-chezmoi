{{ $passphrase := promptStringOnce . "passphrase" "passphrase" -}}
{{ $hostType := promptChoiceOnce . "hostType" "What type of machine is this?" (list "laptop" "server") }}

encryption = "gpg"
[data]
    passphrase = {{ $passphrase | quote }}
    hostType = {{ $hostType | quote }}
[data.features]
    niri = {{ if eq $hostType "laptop" }}true{{ else }}false{{ end }}
    dms = {{ if eq $hostType "laptop" }}true{{ else }}false{{ end }}
[gpg]
    symmetric = true
    args = ["--batch", "--passphrase", {{ $passphrase | quote }}, "--no-symkey-cache"]
